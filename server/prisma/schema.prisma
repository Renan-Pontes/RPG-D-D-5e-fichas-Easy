// Prisma schema — Forja de Heróis backend
// Dev: SQLite. Prod: trocar provider para postgresql e DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())

  characters     Character[]
  ownedCampaigns Campaign[]   @relation("DmCampaigns")
  memberships    Membership[]
  approvals      Approval[]   @relation("RequestedBy")
  reviewed       Approval[]   @relation("ReviewedBy")
  diceRigs       DiceRig[]
}

model Character {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  // A ficha completa em JSON. Mantém compatibilidade com o frontend antigo.
  data       String   // JSON serializado
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships Membership[]
  approvals   Approval[]

  @@index([ownerId])
}

model Campaign {
  id           String   @id @default(cuid())
  dmId         String
  dm           User     @relation("DmCampaigns", fields: [dmId], references: [id], onDelete: Cascade)
  name         String
  slug         String   @unique  // url-friendly
  screenToken  String   @unique  // token para tela pública (TV)
  inviteCode   String   @unique  // código para jogadores entrarem
  description  String?
  // Estado vivo da sessão (iniciativa atual, sessão #, notas do mestre, etc.)
  state        String   @default("{}")  // JSON
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Membership[]
  approvals   Approval[]
  diceRigs    DiceRig[]

  @@index([dmId])
}

model Membership {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  role        String   @default("player") // 'player' | 'dm'
  joinedAt    DateTime @default(now())

  @@unique([campaignId, userId])
  @@index([userId])
}

model Approval {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy  User     @relation("RequestedBy", fields: [requestedById], references: [id])
  reviewedById String?
  reviewedBy   User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])
  type         String   // 'levelup' | 'feature' | 'item' | 'spell' | 'other'
  payload      String   // JSON do que está sendo proposto
  status       String   @default("pending") // 'pending' | 'approved' | 'rejected'
  note         String?
  createdAt    DateTime @default(now())
  reviewedAt   DateTime?

  @@index([campaignId])
  @@index([characterId])
}

// Fila de valores que o mestre pré-define para um jogador.
// Cada DiceRig pode ter um label (ex: "próximos d20 de Renan") e values JSON.
// Quando o jogador rola, consome o primeiro valor não consumido.
model DiceRig {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  targetUserId String
  targetUser   User     @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  diceType     String   @default("d20") // 'd20', 'd6', 'd100', 'any'
  // values: [{value: 15, consumed: false, label: "percepção"}, ...]
  values       String   // JSON
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([campaignId])
  @@index([targetUserId])
}

// Log de todas as rolagens feitas pelo backend, pro mestre acompanhar.
model DiceLog {
  id          String   @id @default(cuid())
  campaignId  String?
  userId      String
  diceType    String
  result      Int
  rigged      Boolean  @default(false) // true se veio de uma DiceRig
  label       String?
  createdAt   DateTime @default(now())

  @@index([campaignId])
  @@index([userId])
}
